# =====================================================================
# Redrob Candidate Ranking System — Environment Configuration (.env)
# =====================================================================
# All relative paths are evaluated from the root of the 'redrob_ranker' directory.

# Path to input candidate dataset (.jsonl or directory)
CANDIDATES_PATH=./data/candidates.jsonl

# Path where the final ranked CSV submission will be generated
OUTPUT_PATH=./output/submission.csv

# Number of top candidates to export in the submission CSV (default: 100)
TOP_N=100

# Enable Stage 2 Cross-Encoder reranking for the top 500 candidates (true / false)
# When true, uses cross-encoder-ms-marco-MiniLM-L6-v2 for higher precision
USE_CROSS_ENCODER=false

# Python runtime configuration (recommended: 1 for unbuffered logging in Docker/CLI)
PYTHONUNBUFFERED=1
